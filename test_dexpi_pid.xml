        <GenericAttribute Name="Power" Value="15" Units="kW"/>
      </GenericAttributes>
      <Nozzle ID="P100-N1"/>
      <Nozzle ID="P100-N2"/>
    </CentrifugalPump>

    <!-- Compressor -->
    <Compressor ComponentClass="Compressor" ID="K-100">
      <GenericAttributes>
        <GenericAttribute Name="TagNameAssignmentClass" Value="K-100"/>
        <GenericAttribute Name="DesignPressure" Value="120" Units="barg"/>
        <GenericAttribute Name="Power" Value="500" Units="kW"/>
      </GenericAttributes>
      <Nozzle ID="K100-N1"/>
      <Nozzle ID="K100-N2"/>
    </Compressor>

    <!-- Export cooler -->
    <PlateHeatExchanger ComponentClass="PlateHeatExchanger" ID="E-102">
      <GenericAttributes>
        <GenericAttribute Name="TagNameAssignmentClass" Value="E-102"/>
